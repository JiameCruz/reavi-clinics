---
import CitasForm from './CitasForm';
---

<section id="contacto">
  <div class="contact-wrapper">
    <div class="contact-info">
      <h2>Agenda tu Cita</h2>
      <p>Selecciona la sede de tu preferencia, el profesional y el servicio que necesitas. Podrás ver los horarios disponibles en tiempo real.</p>
    </div>
    <div class="form-wrapper">
      <CitasForm client:load />
    </div>
  </div>
</section>

<style>
  section {
    padding: 8rem 4rem;
    background-color: var(--color-primary);
    display: flex;
    justify-content: center;
  }

  .contact-wrapper {
    max-width: 1300px;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 6rem;
    align-items: center;
  }

  .contact-info {
    padding-top: 0;
  }

  .contact-info h2 {
    font-size: 4rem;
    font-weight: 800;
    color: #ffffff;
    margin-bottom: 1.5rem;
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .contact-info p {
    font-size: 1.25rem;
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.6;
  }

  .form-wrapper {
    width: 100%;
  }

  @media (max-width: 1024px) {
    .contact-wrapper {
      gap: 4rem;
    }
    .contact-info h2 {
      font-size: 3.5rem;
    }
  }

  @media (max-width: 900px) {
    section {
      padding: 4rem 2rem;
    }
    .contact-wrapper {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .contact-info {
      text-align: center;
    }
  }
</style>
