---
const services = [
  "Dolor de espalda",
  "Lesiones Musculares",
  "Dolor de rodilla",
  "Problemas de Columna",
  "Lesiones deportivas",
  "Dolor de cuello y hombro",
];
---

<div class="service-category">
  <h3 class="category-title">Fisioterapia y Rehabilitación</h3>
  <div class="cards-grid">
    {
      services.map((service) => (
        <div class="card card-primary">
          <h4>{service}</h4>
        </div>
      ))
    }
  </div>
</div>

<style>
  .service-category {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    text-align: left;
  }
  .category-title {
    color: var(--color-primary, #34c1cf);
    font-size: 1.8rem;
    margin: 0;
    font-weight: 700;
  }
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, 180px);
    gap: 1.5rem;
    width: 100%;
  }
  .card {
    background-color: var(--color-primary, #34c1cf);
    color: #ffffff;
    padding: 1.5rem 1rem;
    border-radius: 0; /* Diseño cuadrado, sin bordes redondeados */
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: 120px;
    transition:
      transform 0.3s ease,
      filter 0.3s ease;
    border-radius: 12px;
  }
  .card:hover {
    transform: translateY(-4px);
    filter: brightness(1.1);
  }
  .card h4 {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1.4;
  }
</style>
