<section id="price">
  <div class="header-content">
    <h2 class="section-title">Nuestras Tarifas</h2>
    <p class="section-subtitle">Invierte en tu bienestar con nuestros paquetes especializados.</p>
  </div>
  <div class="prices-container">
    <article class="price-card card-masaje">
      <div class="card-header">
        <h3>Masajes</h3>
        <p>Dos sesiones de masaje o terapia física</p>
      </div>
      <div class="card-price">
        <span class="currency">$</span>500<span class="decimals">.00</span>
      </div>
      <a href="#contacto" class="btn-book">Agendar ahora</a>
    </article>
    <article class="price-card card-fisio">
      <div class="card-header">
        <h3>Fisioterapia</h3>
        <p>Servicios de fisioterapia especializada</p>
      </div>
      <div class="card-price">
        <span class="currency">$</span>450<span class="decimals">.00</span>
      </div>
      <a href="#contacto" class="btn-book">Agendar ahora</a>
    </article>
  </div>
</section>

<style>
  section {
    padding: 8rem 4rem;
    background-color: var(--color-bg);
  }

  .header-content {
    text-align: center;
    margin-bottom: 5rem;
  }

  .section-title {
    font-size: 4rem;
    font-weight: 800;
    margin-bottom: 1rem;
    letter-spacing: -0.03em;
    color: var(--color-text-main);
  }

  .section-subtitle {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .prices-container {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 4rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .price-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 4rem 3.5rem;
    border-radius: 32px;
    color: white;
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .card-masaje {
    background-color: var(--color-secondary);
  }

  .card-masaje:hover {
    transform: translateY(-12px);
    box-shadow: 0 40px 80px rgba(210, 102, 163, 0.3);
  }

  .card-fisio {
    background-color: var(--color-primary);
  }

  .card-fisio:hover {
    transform: translateY(-12px);
    box-shadow: 0 40px 80px rgba(52, 193, 207, 0.3);
  }

  .card-header h3 {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }

  .card-header p {
    font-size: 1.15rem;
    opacity: 0.9;
    line-height: 1.5;
  }

  .card-price {
    font-size: 6.5rem;
    font-weight: 800;
    margin: 4rem 0;
    display: flex;
    align-items: flex-start;
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .currency {
    font-size: 2.5rem;
    margin-top: 0.8rem;
    margin-right: 0.25rem;
    opacity: 0.8;
  }

  .decimals {
    font-size: 1.5rem;
    opacity: 0.8;
    margin-top: 1rem;
    margin-left: 0.25rem;
  }

  .btn-book {
    background: white;
    color: var(--color-text-main);
    font-weight: 700;
    font-size: 1.25rem;
    padding: 1.25rem;
    border-radius: 16px;
    text-align: center;
    text-decoration: none;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .card-masaje .btn-book {
    color: var(--color-secondary);
  }

  .card-fisio .btn-book {
    color: var(--color-primary);
  }

  .btn-book:hover {
    transform: scale(1.02);
  }

  @media (max-width: 1024px) {
    .section-title {
      font-size: 3rem;
    }
    .prices-container {
      gap: 2rem;
    }
    .price-card {
      padding: 3rem 2rem;
    }
    .card-price {
      font-size: 5rem;
    }
  }

  @media (max-width: 768px) {
    section {
      padding: 4rem 2rem;
    }
    .prices-container {
      grid-template-columns: 1fr;
    }
  }
</style>
