<main>
  <section>
    <div class="hero-container">
      <div class="hero-content">
        <p class="hero-tagline">Donde curamos tu dolor</p>
        <h1>Reavi Clinics</h1>
        <p class="hero-description">
          Clínica especializada en fisioterapia y masajes terapéuticos.
          Recuperamos tu bienestar con atención personalizada.
        </p>
        <div class="hero-features">
          <div class="feature">
            <span class="feature-icon">
              <svg
                viewBox="0 0 24 24"
                width="20"
                height="20"
                fill="currentColor"
              >
                <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"
                ></path>
              </svg>
            </span>
            <span>Fisioterapia profesional</span>
          </div>
          <div class="feature">
            <span class="feature-icon">
              <svg
                viewBox="0 0 24 24"
                width="20"
                height="20"
                fill="currentColor"
              >
                <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"
                ></path>
              </svg>
            </span>
            <span>Masajes terapéuticos</span>
          </div>
          <div class="feature">
            <span class="feature-icon">
              <svg
                viewBox="0 0 24 24"
                width="20"
                height="20"
                fill="currentColor"
              >
                <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"
                ></path>
              </svg>
            </span>
            <span>Atención personalizada</span>
          </div>
        </div>
        <div class="hero-cta-group">
          <a href="#contacto" class="btn-primary">Agendar Cita</a>
          <a href="#services" class="btn-secondary">Ver Servicios</a>
        </div>
      </div>
      <div class="hero-visual">
        <div class="image-frame">
          <img src="/img/hero-img.jpg" alt="Reavi Clinics" />
        </div>
      </div>
    </div>
  </section>
</main>

<style>
  .hero-container {
    display: grid;
    min-height: 90vh;
    background-color: var(--color-primary);
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 2rem;
    overflow: hidden;
  }

  .hero-content {
    padding: 8rem 0 8rem 5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    position: relative;
    z-index: 2;
  }

  .hero-tagline {
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    font-weight: 800;
    color: var(--color-secondary);
    margin-bottom: -1rem;
  }

  .hero-content h1 {
    font-size: clamp(5rem, 10vw, 8.5rem);
    font-weight: 900;
    letter-spacing: -0.05em;
    line-height: 0.95;
    color: #ffffff;
    margin-left: -0.05em; /* Optical alignment */
  }

  .hero-description {
    font-size: 1.5rem;
    font-weight: 400;
    line-height: 1.5;
    max-width: 550px;
    color: rgba(255, 255, 255, 0.9);
    margin-top: 1rem;
  }

  .hero-features {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .feature {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 1.15rem;
    font-weight: 600;
    color: #ffffff;
  }

  .feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: var(--color-secondary);
    color: var(--color-white);
    border-radius: 50%;
  }

  .hero-visual {
    position: relative;
    height: 100%;
    display: flex;
    justify-content: flex-end;
    align-items: flex-end;
    padding: 0 0 0 2rem;
  }

  .image-frame {
    position: relative;
    width: 100%;
    height: 90%;
    min-height: 600px;
  }

  .image-frame img {
    position: absolute;
    bottom: -5%; /* Bleeds off the bottom */
    right: 0;
    width: 95%;
    height: 100%;
    border-radius: 400px 0 0 0;
    box-shadow: -40px 40px 80px rgba(0, 0, 0, 0.15);
    z-index: 1;
    object-fit: cover;
    filter: contrast(1.1) saturate(1.1);
    opacity: 0;
    animation: slideInRight 1.2s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: 0.3s;
  }

  .hero-cta-group {
    display: flex;
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .btn-primary {
    background-color: var(--color-secondary);
    color: var(--color-white);
    padding: 1.25rem 2.5rem;
    border-radius: 16px;
    text-decoration: none;
    font-weight: 800;
    font-size: 1.25rem;
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.4s ease;
    box-shadow: 0 10px 30px rgba(210, 102, 163, 0.4);
  }

  .btn-primary:hover {
    transform: translateY(-4px) scale(1.02);
    box-shadow: 0 20px 40px rgba(210, 102, 163, 0.5);
  }

  .btn-secondary {
    background-color: transparent;
    color: #ffffff;
    padding: 1.25rem 2.5rem;
    border-radius: 16px;
    border: 3px solid rgba(255, 255, 255, 0.3);
    text-decoration: none;
    font-weight: 800;
    font-size: 1.25rem;
    transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .btn-secondary:hover {
    background-color: #ffffff;
    color: var(--color-primary);
    border-color: #ffffff;
    transform: translateY(-4px);
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes slideInRight {
    from {
      opacity: 0;
      transform: translateX(100px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .hero-content h1,
  .hero-tagline,
  .hero-description,
  .feature,
  .hero-cta-group {
    opacity: 0;
    animation: fadeInUp 1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .hero-tagline {
    animation-delay: 0.1s;
  }
  .hero-content h1 {
    animation-delay: 0.2s;
  }
  .hero-description {
    animation-delay: 0.3s;
  }
  .feature:nth-child(1) {
    animation-delay: 0.4s;
  }
  .feature:nth-child(2) {
    animation-delay: 0.5s;
  }
  .feature:nth-child(3) {
    animation-delay: 0.6s;
  }
  .hero-cta-group {
    animation-delay: 0.7s;
  }

  @media (prefers-reduced-motion: reduce) {
    * {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
    .hero-content h1,
    .hero-tagline,
    .hero-description,
    .feature,
    .hero-cta-group,
    .image-frame img {
      opacity: 1 !important;
      transform: none !important;
    }
  }

  @media (max-width: 1024px) {
    .hero-content {
      padding: 4rem 0 4rem 3rem;
    }
    .image-frame img {
      border-radius: 200px 0 0 0;
    }
  }

  @media (max-width: 768px) {
    .hero-container {
      grid-template-columns: 1fr;
      min-height: auto;
      gap: 0;
      padding-bottom: 4rem;
    }

    .hero-content {
      padding: 4rem 2rem 2rem;
      align-items: center;
      text-align: center;
      z-index: 2;
    }

    .hero-content h1 {
      font-size: clamp(4rem, 15vw, 6rem);
    }

    .hero-description {
      text-align: center;
      font-size: 1.25rem;
    }

    .hero-features {
      align-items: center;
    }

    .hero-visual {
      padding: 0;
      justify-content: center;
      height: 400px;
    }

    .image-frame {
      width: 100%;
      height: 100%;
    }

    .image-frame img {
      position: relative;
      bottom: auto;
      right: auto;
      width: 90%;
      height: 100%;
      margin: 0 auto;
      border-radius: 200px 200px 20px 20px;
    }
    
    .hero-cta-group {
      flex-direction: column;
      width: 100%;
      max-width: 300px;
    }
  }
</style>
