---

---

<section id="price">
  <h2>Precios</h2>
  <div class="prices-container">
    <article>
      <h3>Masajes</h3>
      <h4>Dos sesiones de masaje o terapia física</h4>
      <a href="/contact"><button>$500.00</button></a>
    </article>
    <article>
      <h3>Fisioterapia</h3>
      <h4>Servicios de fisioterapia especializada</h4>
      <a href="/contact"><button>$450.00</button></a>
    </article>
  </div>
</section>

<style>
  section {
    padding: 2rem;
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: column;
    gap: 1rem;
  }

  .prices-container {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  article {
    border: 2px solid var(--color-primary);
    padding: 2rem;
    background: #f8fafc;
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }

  article h3 {
    color: var(--color-primary);
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }

  article h4 {
    color: var(--color-text-main);
    margin-bottom: 0.5rem;
    font-size: 1rem;
  }

  article a {
    text-decoration: none;
    color: white;
    width: 100%;
    display: flex;
    justify-content: center;
  }

  article a button {
    width: 80%;
    font-size: 20px;
    font-weight: bold;
    padding: 0.6rem 1.5rem;
    background-color: var(--color-primary);
    color: white;
    border: none;
    cursor: pointer;
    transition: var(--transition-smooth);
  }

  article a button:hover {
    background-color: var(--color-secondary);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .prices-container {
      grid-template-columns: 1fr;
    }
  }
</style>
