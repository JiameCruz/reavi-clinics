---
interface Props {
  title?: string;
}

const { title = "Reavi Clinics - Fisioterapia y Masajes" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/img/Logo.jpg" />
    <meta name="generator" content={Astro.generator} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    /* Color Palette - Reavi Clinics */
    --color-primary: #34c1cf;
    --color-primary-deep: #2ba8b5;
    --color-secondary: #d266a3;
    --color-tertiary: #cfbb34;

    /* Neutral Colors */
    --color-bg: #f8fafc;
    --color-white: #ffffff;
    --color-text-main: #334155;
    --color-text-muted: #64748b;

    /* Transitions & Animations */
    --duration-soft: 0.4s;
    --ease-soft: cubic-bezier(0.4, 0, 0.2, 1);
    --transition-smooth: all var(--duration-soft) var(--ease-soft);
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: "Outfit", system-ui, sans-serif;
    background-color: var(--color-bg);
    color: var(--color-text-main);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }
</style>
